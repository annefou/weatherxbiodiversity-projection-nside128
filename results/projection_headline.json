    "tier1_posterior": "results/posterior_bambi_healpix.nc",
    "design_columns": [
      "Intercept",
      "sc_sampling",
      "sc_TEI_bs",
      "sc_TEI_delta",
      "sc_TEI_bs:sc_TEI_delta",
      "sc_PEI_bs",
      "sc_PEI_delta",
