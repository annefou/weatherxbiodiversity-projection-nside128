# Generated notebooks (kept as jupytext .py source-of-truth)
notebooks/*.ipynb
notebooks/.ipynb_checkpoints/

# MyST / Jupyter Book build output
_build/
public/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Environment / OS
.DS_Store
.env

# Data — never committed; downloaded on first run
data/*
!data/.gitkeep
!data/README.md
# Exception: GBIF citation metadata — small, citation provenance, must be tracked
!data/gbif_bombus_iberia_metadata.json
# Exception: precomputed Iberian HEALPix cell indices — small + deterministic,
# committed so the pipeline boots from a stable substrate definition.
!data/precomputed/
!data/precomputed/**

# Tier 2 — DestinE Climate DT (licence-locked redistribution)
# Raw NetCDF extracts and per-cell rasters approach a climate fingerprint;
# only the aggregated species-level summary JSON + the figures are committed.
data/destine/
# Future TEI/PEI rasters (DestinE-derived; matches *future*_healpix.nc and
# any future variants).
healpix_port/outputs_iberia/*future*
# Per-cell projection rasters at any resolution. Globbed pattern so
# higher-resolution outputs added later are also automatically covered.
results/projection_*.nc
results/projection_per_cell_*.npy
# Allow only the headline JSON (aggregated to species level — explicitly
# committable per the licence boundary).
!results/projection_headline.json

# Paper PDFs (single PDF allowed; subfolder build artefacts ignored)
paper/_build/
paper/.tmp/

# Figures generated by notebooks (keep curated examples in figures/)
notebooks/figures/

# Reference / external archives (Soroye Figshare extract); also covers the
# `reference` symlink used during local dev to share Bumblebee_repo across siblings.
reference/
reference

# Results — large numerical outputs (commit only summary CSVs you reference in figures)
results/raw/
results/logs/
# results/posterior_bambi_healpix.nc IS tracked (bambi MCMC posterior, ~5 MB)

# Docker
docker-image.tar.gz

# HEALPix-NESTED nside=128 substrate-robustness branch (Option C) — outputs
# regenerated by `snakemake`. The bambi NetCDF lives under
# results/posterior_bambi_healpix.nc (tracked).
healpix_port/outputs_iberia/*
!healpix_port/outputs_iberia/.gitkeep

# Snakemake metadata
.snakemake/

# Claude scratch
.claude/.cache/
.claude/local/
